# ════════════════════════════════════════════════════════════════
# SeoulSky 환경 변수 — 전부 선택 사항(OPTIONAL).
#
# 핵심 /sky 장면은 키가 하나도 없어도 완전히 동작합니다:
#   Open-Meteo(예보) + RainViewer(레이더 접근 신호)는 키 불필요.
# 아래 키는 전부 "보강(enrichment)"이며, 각 기능은 키가 없거나 실패하면
# 스스로 null / [] 로 우아하게 강등됩니다 — 키가 없다고 장면이 깨지지 않습니다.
#
# 사용법:  cp .env.example .env.local  →  값 입력  →  dev 서버 재시작
# 모든 키는 서버 전용이며, NEXT_PUBLIC_ 접두어가 없는 한 클라이언트에
# 노출되지 않습니다(현재 NEXT_PUBLIC_ 변수는 없음).
# ════════════════════════════════════════════════════════════════


# ─── 예보 소스 (선택적 교차 검증 · Open-Meteo가 키 불필요 기본 워크호스) ───

# MET Norway (Locationforecast) — 무료·키 불필요. 단, MET 이용약관상 User-Agent에
#   실제 연락처(이메일 또는 URL)가 반드시 포함되어야 합니다. 연락처가 없으면 MET가
#   HTTP 403을 반환하고 provider는 needs-config로 보고되어 호출되지 않습니다.
#   형식: "AppName/version 연락처".  (read: lib/providers/met-norway.ts:27)
MET_NO_USER_AGENT=SeoulSky/1.0 you@example.com

# 기상청 단기예보 (data.go.kr 활용신청). Encoding/Decoding 키 어느 쪽이든 동작.
#   미설정 → KMA 예보/관측 보강 생략.  (read: lib/providers/kma.ts:50)
KMA_SHORT_TERM_API_KEY=

# Pirate Weather (pirateweather.net 무료 키). 미설정 → 해당 소스 생략.
#   (read: lib/providers/pirate-weather.ts:24)
PIRATE_WEATHER_API_KEY=

# WeatherAPI.com (weatherapi.com 무료 키). 미설정 → 해당 소스 생략.
#   (read: lib/providers/weather-api.ts:23)
WEATHERAPI_KEY=


# ─── 대기질 (선택) ───

# AirKorea (data.go.kr 한국환경공단_에어코리아_대기오염정보).
#   미설정 → Open-Meteo 대기질(키 불필요)로 자동 폴백, 그다음 null.
#   haze/가시거리에 미세하게만 반영 — 경고/의료성 카피는 절대 없음.
#   (read: lib/providers/air-quality.ts:62)
AIRKOREA_API_KEY=


# ─── 기상특보 (선택) ───

# 기상청 기상특보 (data.go.kr) — 위 단기예보 키와는 별개 서비스.
#   미설정 → 특보는 []로 강등(예보 확률로 지어내지 않음).
#   (read: lib/providers/kma.ts:55)
KMA_WARNING_API_KEY=


# ─── 레이더 영상 (KMA API허브 — 선택 · Vercel Hobby에서는 생략 권장) ───

# KMA API허브 레이더 authKey (apihub.kma.go.kr — HSR 500m 반사도).
#   /sky 03 섹션의 강수 에코를 서버에서 CARTO 베이스맵 위에 렌더링합니다.
#   키와 ~13MB 격자는 클라이언트에 절대 도달하지 않고 작은 에코 PNG만 전송.
#   미설정 → 레이더 섹션은 베이스맵 + 한글 라벨만 표시(빈 상태), 나머지는 영향 없음.
#   주의: 격자 fetch + 재투영이 무거워 Vercel Hobby의 콜드스타트/실행시간 한도를
#         넘을 수 있음. 그럴 땐 생략하세요 — 나머지는 전부 키 불필요.
#   (read: lib/radar/apihub.ts:30,37)
KMA_APIHUB_KEY=

# 레이더 지오레퍼런스 캐시 디렉터리(선택). lat/lon 격자에서 1회 빌드되어 디스크에
#   캐시됩니다. 기본값: ./data/radar (gitignore됨). 읽기전용/서버리스 FS에서는
#   쓰기 가능 경로(예: /tmp/radar)로 지정해야 콜드스타트마다 재fetch하지 않습니다.
#   (read: lib/radar/apihub.ts:41)
RADAR_DATA_DIR=


# ─── 멀티소스 강수 합의 (선택 · 기본 OFF) ───

# 마스터 스위치("1"이면 활성). 활성 시 /api/sky의 일별 POP/predicted_mm이
#   단일 Open-Meteo 경로 대신 여러 예보 소스의 가중 합의로 산출됩니다.
#   미설정/"0" → 기존 단일 소스 출력 그대로(byte-for-byte).
#   (read: app/api/sky/route.ts:31)
MULTI_SOURCE_PRECIP=

# 멀티소스 예보 fan-out 공유 캐시 TTL(ms, 선택). 한 주기 내 동시 요청이 한 번의
#   업스트림 호출을 공유. MULTI_SOURCE_PRECIP=1일 때만 유효. 기본값 720000(~12분).
#   (read: lib/reliability/forecastSources.ts:38)
FORECAST_CACHE_TTL_MS=

# 멀티소스 소스별 타임아웃(ms, 선택). 느린 소스 하나가 응답을 막지 못하도록 드롭.
#   MULTI_SOURCE_PRECIP=1일 때만 유효. 기본값 4000.
#   (read: lib/reliability/forecastSources.ts:40)
PER_SOURCE_TIMEOUT_MS=


# ─── 강수 신뢰도 학습 (GitHub Actions cron 전용 — 웹 런타임 미사용) ───
# 매일 배치(.github/workflows/precip-reliability.yml → scripts/precip-reliability.ts)가
# 예보 스킬을 채점해 학습 가중치를 영속 저장합니다. Action용 repo Secrets로 설정하세요.
# 로컬에서는 스크립트를 직접 돌릴 때만 의미가 있습니다. 자세히: lib/reliability/README.md.

# 지상 관측 진실값 키: 기상청 지상(ASOS) 일자료 조회서비스(data.go.kr
#   AsosDalyInfoService) — 단기예보 키와는 별도 구독. 미설정 시 KMA_SHORT_TERM_API_KEY로
#   폴백하나, 그 키가 ASOS 미구독이면 403 → 해당 일자 채점 건너뜀(값 지어내지 않음).
#   cron/스크립트 전용.  (read: lib/reliability/groundTruth.ts:22)
KMA_OBSERVATION_API_KEY=

# Hedge 학습률 η(선택). 클수록 가중치가 빠르게 이동. 기본값 0.5. cron/스크립트 전용.
#   (read: lib/reliability/weights.ts:35)
RELIABILITY_ETA=

# 신뢰도 상태 디렉터리(선택). 기본값: ./data/reliability.
#   cron이 학습 가중치를 여기에 WRITE하고, 웹 런타임은 위 합의를 게이트하기 위해
#   여기서 READ합니다. CI에서는 영속 저장소를 가리키도록 변경 가능.
#   (read: lib/reliability/store.ts:22)
RELIABILITY_DATA_DIR=


# ─── 디버그 (선택) ───

# "1"이면 /api/sky 응답에 precipWeighting 디버그 블록 노출
#   (mode/reason/confidence + 기여 소스/유효 가중치). 프로덕션에서는 미설정 권장 —
#   off일 때 공개 페이로드는 변하지 않음.  (read: app/api/sky/route.ts:33)
RELIABILITY_DEBUG=
