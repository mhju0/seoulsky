# ────────────────────────────────────────────────────────────────
# SeoulSky 환경 변수 — 전부 선택 사항입니다.
# 키가 하나도 없어도 앱은 Open-Meteo만으로 완전히 동작합니다.
#
# 사용법:  cp .env.example .env.local  →  값 입력  →  서버 재시작
# ────────────────────────────────────────────────────────────────

# ─── MET Norway (선택, 무료) ─────────────────────────────────────
# MET Norway 이용약관은 연락처가 포함된 식별 가능한 User-Agent를 요구합니다.
# 설정해야만 활성화됩니다(없으면 needs-config — 공개 씬은 Open-Meteo로 계속 동작).
# 연락처는 서버에서만 사용되고 공개 UI에는 노출되지 않습니다.
# 예: SeoulSky/1.0 you@example.com
MET_NO_USER_AGENT=

# ─── 기상청 KMA (선택, 무료) ─────────────────────────────────────
# 공공데이터포털(data.go.kr) 무료 가입 후 두 서비스를 각각 활용신청합니다.
# 두 키는 서로 독립적이며 각각 선택 사항입니다(하나만 있어도 됩니다).
# Encoding / Decoding 키 어느 쪽이든 동작하며, 키는 서버 전용입니다.

# 기상청 단기예보 조회서비스
KMA_SHORT_TERM_API_KEY=

# 기상청 기상특보 조회서비스
KMA_WARNING_API_KEY=

# ─── AirKorea 대기질 (선택, 무료) ────────────────────────────────
# 공공데이터포털(data.go.kr)에서 "한국환경공단_에어코리아_대기오염정보"
# 활용신청 → 인증키 발급. 없으면 Open-Meteo 대기질(키 불필요)로 자동 대체됩니다.
# 설정 시: 종로구 측정소의 공식 PM2.5/PM10/통합지수가 우선 사용됩니다. 서버 전용.
AIRKOREA_API_KEY=

# ─── 시네마틱 비디오 플레이트 (선택, 기본 비활성) ───────────────────
# 실시간 3D 씬은 이 파일들 없이 완전히 동작합니다. 외부에서 제작한
# 시네마틱 영상(public/cinematic/<key>.webm)을 씬 위에 합성하려면 1로 설정.
# 사양은 public/cinematic/README.md 참고. (Higgsfield 등과 무관·비제휴)
NEXT_PUBLIC_CINEMATIC_PLATES=0
