# ────────────────────────────────────────────────
# SeoulSky 환경 변수 — 전부 선택 사항.
# 키가 하나도 없어도 Open-Meteo만으로 앱은 완전히 동작합니다.
# 사용법: cp .env.example .env.local → 값 입력 → 서버 재시작
# 모든 키는 서버 전용이며 공개 UI에 노출되지 않습니다.
# ────────────────────────────────────────────────

# ─── 예보 소스 (교차 검증, 5종) ───────────────────
# 1) Open-Meteo   — 키 불필요, 항상 활성 (기본 워크호스)
# 2) MET Norway   — 무료. 연락처 포함 User-Agent 필수.
#                   예: SeoulSky/1.0 you@example.com
MET_NO_USER_AGENT=SeoulSky/1.0 michaelju0418@gmail.com
# 3) 기상청 단기예보 — data.go.kr 활용신청. Encoding/Decoding 키 어느 쪽이든 동작.
KMA_SHORT_TERM_API_KEY=
# 4) Pirate Weather — pirateweather.net 무료 키
PIRATE_WEATHER_API_KEY=
# 5) WeatherAPI.com — weatherapi.com 무료 키
WEATHERAPI_KEY=

# ─── 기타 데이터 (선택) ───────────────────────────
# 기상청 기상특보 — data.go.kr 활용신청
KMA_WARNING_API_KEY=
# 기상청 고해상도 레이더 — API허브(apihub.kma.go.kr) "레이더 합성(CMP)" 활용신청.
#   /sky 강수 레이더 스코프가 사용하는 원시 반사도 격자(HSR, ~500m)를 서버에서 직접
#   렌더링합니다. 서버 전용(NEXT_PUBLIC_ 아님) — 키와 ~13MB 격자는 클라이언트에 절대
#   도달하지 않고, 작은 에코 PNG만 전송됩니다. 미설정 시 레이더 섹션은 빈 상태로 표시.
KMA_APIHUB_KEY=your_apihub_key_here
# 레이더 지오레퍼런스 캐시 디렉터리(선택). lat/lon 격자에서 1회 빌드되어 디스크에
#   캐시됩니다. 기본값: ./data/radar (gitignore됨). 런타임에선 /tmp 등으로 변경 가능.
RADAR_DATA_DIR=
# AirKorea 대기질 — data.go.kr "한국환경공단_에어코리아_대기오염정보".
#                   없으면 Open-Meteo 대기질(키 불필요)로 자동 대체.
AIRKOREA_API_KEY=

# ─── 강수 신뢰도 배치 (오프라인 전용, 런타임 미사용) ──
# 로컬 실행은 .env.local 사용. 매일 자동 실행은 .github/workflows/precip-reliability.yml
#   (GitHub Action)이 동일한 이름의 repo Secrets에서 키를 주입하며, 학습 상태
#   (data/reliability/*)를 reliability-state 브랜치에 커밋해 런 간 영속 보존합니다.
#   자세한 내용: lib/reliability/README.md "Deployment".
# 지상 관측 진실값(ground truth): 기상청 지상(ASOS) 일자료 조회서비스 키.
#   data.go.kr "기상청_지상(종관, ASOS) 일자료 조회서비스"(AsosDalyInfoService) 별도 활용신청.
#   미설정 시 KMA_SHORT_TERM_API_KEY로 자동 폴백하지만, 단기예보 키가
#   ASOS 서비스에 미구독이면 403 → 해당 일자 채점은 건너뜁니다(값을 지어내지 않음).
KMA_OBSERVATION_API_KEY=
# 배치 산출물 디렉터리(선택). 기본값: ./data/reliability (cron/CI에서 영속 저장소로 변경 가능).
RELIABILITY_DATA_DIR=
# Phase 2 Hedge 학습률 η(선택). 클수록 가중치가 빠르게 움직임. 기본값 0.5.
RELIABILITY_ETA=
# Phase 3 디버그(선택). 1이면 /api/sky 응답에 precipWeighting 디버그 필드를 노출
#   (mode/reason/confidence + Phase 4의 contributed sources/effective weights).
#   프로덕션에서는 비활성(기본값) — 공개 페이로드는 변하지 않음.
RELIABILITY_DEBUG=
# Phase 4 멀티소스 강수 합의(선택, 기본 OFF). 1이면 /api/sky의 일별 POP/predicted_mm을
#   여러 예보 소스의 가중 합의로 산출(런타임 출력이 처음으로 바뀌는 단계 —
#   학습 전에도 등가중 합의로 기준선이 이동). 미설정/0이면 기존 Open-Meteo 단일 경로 그대로.
MULTI_SOURCE_PRECIP=
# Phase 4 멀티소스 예보 공유 캐시 TTL(ms, 선택). 한 주기 동안 동시 요청이 한 번의
#   업스트림 호출을 공유. 기본값 720000(~12분).
FORECAST_CACHE_TTL_MS=
# Phase 4 소스별 타임아웃(ms, 선택). 느린 소스 하나가 응답을 막지 못하도록 드롭. 기본값 4000.
PER_SOURCE_TIMEOUT_MS=

# ─── 시네마틱 플레이트 (기본 활성) ────────────────
# 1 = 영상 베이스 + 실시간 3D 효과 합성, 0 = 절차적 3D만.
# 영상은 오프라인(Claude CLI Higgsfield)에서 생성, 런타임 호출 없음.
NEXT_PUBLIC_CINEMATIC_PLATES=1