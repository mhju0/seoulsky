# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# precipitation source-reliability batch outputs (runtime-generated; never commit
# — no real/fabricated observation data belongs in the repo). Dir kept via .gitkeep.
# Includes the Phase 2 weight state (source-weights.json), which must instead be
# persisted to durable storage across scheduled runs (see lib/reliability/README.md).
/data/reliability/*.jsonl
/data/reliability/*.json

# radar georeference cache (built once from the KMA latlon grids; regenerable)
/data/radar/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local design/research artifacts; canonical public docs remain trackable
/docs/*PLAN*.md
/docs/*RUNBOOK*.md
/docs/descent-recon.md
/docs/cinematic-plates.md
/docs/shot-prompts.md
/docs/design/

# Local assistant and editor configuration. These files support individual
# workflows but are not part of the application or its public documentation.
.claude/
.serena/
.agents/
.cursor/
.codex/
.aider*
CLAUDE.md
AGENTS.md
GEMINI.md
skills-lock.json
.github/copilot-instructions.md

# Local source-media archives are not used by the runtime.
/public/cinematic/generated/
/public/cinematic/locations/

pnpm-lock.yaml
pnpm-workspace.yaml
