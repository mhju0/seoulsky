# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# generated cinematic video assets — large binaries. Host via Git LFS, object
# storage (Vercel Blob / S3) or a CDN; keep the README + manifest tracked.
/public/cinematic/generated/*.webm
/public/cinematic/generated/*.mov
/public/cinematic/generated/*.png
/public/cinematic/locations/*.webm
/public/cinematic/locations/*.mov
/public/cinematic/locations/*.png

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# precipitation source-reliability batch outputs (runtime-generated; never commit
# — no real/fabricated observation data belongs in the repo). Dir kept via .gitkeep.
# Includes the Phase 2 weight state (source-weights.json), which must instead be
# persisted to durable storage across scheduled runs (see lib/reliability/README.md).
/data/reliability/*.jsonl
/data/reliability/*.json

# radar georeference cache (built once from the KMA latlon grids; regenerable)
/data/radar/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/docs/

# claude
CLAUDE.md